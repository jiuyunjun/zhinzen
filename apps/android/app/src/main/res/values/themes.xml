<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Compose handles app theming; this base theme just provides a no-action-bar
         window with the brand background, avoiding a Material Components dependency. -->
    <style name="Theme.Zhinzen" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/zz_bg</item>
        <item name="android:statusBarColor">@color/zz_bg</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>
