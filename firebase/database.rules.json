{
  "rules": {
    "liveLocations": {
      "$roomId": {
        ".read": true,
        "$deviceId": {
          ".write": true,
          ".validate": "newData.hasChildren(['deviceId', 'lat', 'lng', 'updatedAt', 'sharingLocation'])",
          "deviceId": { ".validate": "newData.val() === $deviceId" },
          "lat": { ".validate": "newData.isNumber() && newData.val() >= -90 && newData.val() <= 90" },
          "lng": { ".validate": "newData.isNumber() && newData.val() >= -180 && newData.val() <= 180" },
          "accuracy": { ".validate": "newData.isNumber() && newData.val() >= 0" },
          "heading": { ".validate": "newData.isNumber() || newData.val() === null" },
          "speed": { ".validate": "newData.isNumber()" },
          "updatedAt": { ".validate": "newData.isNumber()" },
          "sharingLocation": { ".validate": "newData.isBoolean()" },
          "displayName": { ".validate": "newData.isString()" },
          "battery": { ".validate": "(newData.isNumber() && newData.val() >= 0 && newData.val() <= 100) || newData.val() === null" },
          "$other": { ".validate": false }
        }
      }
    },
    "rallyPoints": {
      "$roomId": {
        ".read": true,
        "$pointId": {
          ".write": true,
          ".validate": "!newData.exists() || newData.hasChildren(['name', 'lat', 'lng', 'createdByDeviceId', 'createdAt'])",
          "name": { ".validate": "newData.isString() && newData.val().length <= 60" },
          "lat": { ".validate": "newData.isNumber() && newData.val() >= -90 && newData.val() <= 90" },
          "lng": { ".validate": "newData.isNumber() && newData.val() >= -180 && newData.val() <= 180" },
          "createdByDeviceId": { ".validate": "newData.isString()" },
          "createdAt": { ".validate": "newData.isNumber()" },
          "$other": { ".validate": false }
        }
      }
    },
    "tracks": {
      "$roomId": {
        ".read": true,
        "$deviceId": {
          "$pointId": {
            ".write": "!data.exists() && newData.exists()",
            ".validate": "newData.hasChildren(['deviceId', 'lat', 'lng', 'createdAt'])",
            "deviceId": { ".validate": "newData.val() === $deviceId" },
            "lat": { ".validate": "newData.isNumber() && newData.val() >= -90 && newData.val() <= 90" },
            "lng": { ".validate": "newData.isNumber() && newData.val() >= -180 && newData.val() <= 180" },
            "accuracy": { ".validate": "newData.isNumber() && newData.val() >= 0" },
            "heading": { ".validate": "newData.isNumber() || newData.val() === null" },
            "speed": { ".validate": "newData.isNumber()" },
            "createdAt": { ".validate": "newData.isNumber()" },
            "$other": { ".validate": false }
          }
        }
      }
    },
    "rooms": {
      "$roomId": {
        "uwb": {
          ".read": true,
          ".write": true
        }
      }
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
