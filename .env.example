# Copy to .env.local and fill in real values. .env.local is gitignored.
# All VITE_* vars are bundled into the client at build time (not secret).

# Google Maps JavaScript API key.
# Restrict it by HTTP referrer + to the Maps JavaScript API in the GCP console.
VITE_MAPS_API_KEY=

# Firebase web app config — Firebase console:
#   Project settings → General → Your apps → (Web app) → SDK setup and config.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_DATABASE_URL=
